# Pipefy API credentials
PIPEFY_TOKEN=your_pipefy_api_token_here

# HTTP server port (leave unset to run in stdio mode)
PORT=3000

# URL pública do servidor (usada nos redirects OAuth e nas instruções exibidas ao usuário)
SERVER_BASE_URL=https://seu-servidor.railway.app

# Microsoft Entra ID (Azure AD) — obrigatório para autenticação via Microsoft
# Crie um App Registration em https://portal.azure.com e preencha abaixo:
AZURE_CLIENT_ID=your_azure_app_client_id
AZURE_CLIENT_SECRET=your_azure_app_client_secret
AZURE_TENANT_ID=your_azure_tenant_id

# Segredo para assinar os tokens de sessão (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your_random_session_secret_here
